# API Settings
API__PORT=8000
API__TITLE=BE Answer Hub API
API__DESCRIPTION=API for BE Answer Hub
API__VERSION=0.0.1

# Database Connection (PostgreSQL)
DATABASE__HOST=postgres
DATABASE__PORT=5432
DATABASE__USER=postgres
DATABASE__PASSWORD=postgres
DATABASE__NAME=answer_hub
DATABASE__POOL_SIZE=20
DATABASE__MAX_OVERFLOW=10

# Logger Settings
LOGGER__LEVEL=INFO

# S3 / MinIO (object storage for CV PDFs)
# Use http://minio:9000 when the app runs inside Docker.
# Use http://localhost:9000 when running the app on the host.
S3__ENDPOINT_URL=http://minio:9000
S3__ACCESS_KEY=minioadmin
S3__SECRET_KEY=minioadmin
S3__BUCKET=cv-files
S3__REGION=us-east-1
S3__PRESIGNED_TTL=3600
S3__PORT=9000
S3__CONSOLE_PORT=9001
